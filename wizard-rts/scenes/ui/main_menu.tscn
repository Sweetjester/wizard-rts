[node name="Class" type="Label" parent="RootMargin/Layout/CharacterPanel/CharacterScroll/CharacterCards/HellfireBabyCard/CardLayout/TextLayout"]
layout_mode = 2
theme_override_colors/font_color = Color(0.909804, 0.352941, 0.352941, 1)
theme_override_font_sizes/font_size = 16
text = "Bright, careful, flame-born."

[node name="Description" type="RichTextLabel" parent="RootMargin/Layout/CharacterPanel/CharacterScroll/CharacterCards/HellfireBabyCard/CardLayout/TextLayout"]
custom_minimum_size = Vector2(740, 150)
layout_mode = 2
size_flags_horizontal = 3
bbcode_enabled = true
scroll_active = true
text = "No longer a child, but her parents were singed as she was born with the ability to wield flame. She was quickly adopted by the arcana school to shape her into the polite, talented wizard she is today.\n\nNot quick to turn to violence, but embraces her abilities when they are needed."

