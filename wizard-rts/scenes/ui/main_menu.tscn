[node name="Description" type="RichTextLabel" parent="RootMargin/Layout/CharacterPanel/CharacterScroll/CharacterCards/BadKonCard/CardLayout/TextLayout"]
custom_minimum_size = Vector2(1, 170)
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
bbcode_enabled = true
fit_content = false
scroll_active = false
text = "For generations, Kon belonged to a cult of wizards who observed the ferocious cycle of evolution, until evolution produced horrors so vile the cult had no choice but to seal them away.\n\nKon saw tools, and was willing. He is void of empathy, he can and will unleash the horrors."

