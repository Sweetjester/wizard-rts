theme_override_font_sizes/font_size = 24
text = "Bad Kon Willow - Life Wizard"

[node name="Class" type="Label" parent="RootMargin/Layout/CharacterPanel/CharacterScroll/CharacterCards/BadKonCard/CardLayout/TextLayout"]
layout_mode = 2
theme_override_colors/font_color = Color(0.482353, 0.866667, 0.909804, 1)
theme_override_font_sizes/font_size = 16
text = "Miserable, and discarded."

[node name="Description" type="RichTextLabel" parent="RootMargin/Layout/CharacterPanel/CharacterScroll/CharacterCards/BadKonCard/CardLayout/TextLayout"]
custom_minimum_size = Vector2(740, 150)
layout_mode = 2
size_flags_horizontal = 3
bbcode_enabled = true
scroll_active = true
text = "For generations, Kon belonged to a cult of wizards who observed the ferocious cycle of evolution - watching life tear itself apart in a cycle of domination.They were students, not interventionists. Until evolution produced horrors so vile the cult had no choice but to seal them away.\n\nKon cared not.\n\nKon saw tools, and was willing. \"hang from willow\" they told him. A curse spoken often enough ny his kin it's now tethered to his very identity.\n\nHe is void of empathy, he can and will unleash the horrors."

